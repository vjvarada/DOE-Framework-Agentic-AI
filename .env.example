# Agent Creator — Environment Variables
# Copy this file to .env and fill in your API keys
# NEVER commit .env to git!

# LiteLLM (local dev only — CommandCenter injects at runtime)
LITELLM_BASE_URL=http://127.0.0.1:8080
LITELLM_MASTER_KEY=sk-local

# AI providers (optional — Copilot handles AI tasks directly)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# External services (optional)
# APIFY_API_TOKEN=
# SERPAPI_API_KEY=
# INSTANTLY_API_KEY=
