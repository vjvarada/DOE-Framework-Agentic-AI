# ═══════════════════════════════════════════════════════════════════
# Agent Website Manager — Environment Variables
# Copy this file to .env and fill in your credentials
# NEVER commit .env to git!
# ═══════════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────────

# Hostinger hPanel API token (get from hPanel → API)
HOSTINGER_API_TOKEN=

# WordPress REST API credentials
WORDPRESS_SITE_URL=https://yourdomain.com
WORDPRESS_USERNAME=admin
WORDPRESS_APP_PASSWORD=

# ── Optional ──────────────────────────────────────────────────────

# WooCommerce REST API
#WOOCOMMERCE_CONSUMER_KEY=ck_xxxxxxxx
#WOOCOMMERCE_CONSUMER_SECRET=cs_xxxxxxxx

# Elementor (for Elementor Cloud features)
#ELEMENTOR_API_KEY=

# Google APIs (shared key for PageSpeed, Analytics, Search Console)
#GOOGLE_API_KEY=
#PAGESPEED_API_KEY=

# Google Analytics 4 (OAuth required — see .tmp/scripts/fetch_analytics.py)
#GOOGLE_ANALYTICS_PROPERTY_ID=

# Google Search Console (OAuth required — see .tmp/scripts/fetch_search_console.py)
#GOOGLE_SEARCH_CONSOLE_SITE=
# For domain property use: sc_domain:example.com
# For URL prefix use: https://example.com/

# OAuth credentials file path
#GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# Google Sheets (for reporting)
#GOOGLE_SHEETS_CREDENTIALS_FILE=

# LLM keys (only needed for standalone mode — Copilot handles AI tasks)
#OPENAI_API_KEY=
#ANTHROPIC_API_KEY=

# LiteLLM (local dev only — CommandCenter injects at runtime)
#LITELLM_BASE_URL=http://127.0.0.1:8080
#LITELLM_MASTER_KEY=sk-local
