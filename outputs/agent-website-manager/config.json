    "hostinger": {
      "command": "npx",
      "args": ["-y", "@hostinger/mcp-server"],
      "env": {
        "HOSTINGER_API_TOKEN": "${HOSTINGER_API_TOKEN}"
      }
    }
  },
  "icon": "Globe",
  "category": "web",
  "webhook_routes": []
