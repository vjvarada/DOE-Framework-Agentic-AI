  "version": "0.1.0",
  "skill_repos": [],
  "integrations": [
    "hostinger",
    "wordpress-rest-api",
    "woocommerce"
  ],
  "optional_integrations": [
    "openai",
    "anthropic",
    "google-sheets",
    "google-analytics",
    "google-search-console",
    "google-pagespeed-insights"
  ],
  "tags": [
    "wordpress",
    "hostinger",
    "website",
    "elementor",
    "woocommerce",
    "hosting",
    "web-development",
    "seo",
    "performance",
    "caching",
    "media-optimization",
    "devops"
  ],
  "tool_scope": null,
  "max_mutation_attempts": 1,
