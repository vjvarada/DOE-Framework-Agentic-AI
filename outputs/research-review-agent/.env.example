# Environment Variables for Research Review Agent
# Copy this file to .env and fill in your API keys
# NEVER commit .env to git!

# === OPTIONAL API KEYS (services work without them, but with limits) ===

# Semantic Scholar - Optional, provides higher rate limits
# Get key at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# CrossRef - Optional, provide your email for polite pool (faster responses)
CROSSREF_EMAIL=

# Unpaywall - Optional, provide your email
UNPAYWALL_EMAIL=

# CORE API - Optional, required for CORE paper fetching
# Get key at: https://core.ac.uk/services/api
CORE_API_KEY=

# SerpAPI - Optional, required for Google Scholar search
# Get key at: https://serpapi.com/
SERPAPI_API_KEY=
